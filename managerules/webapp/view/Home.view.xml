<mvc:View controllerName="managerules.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    >

   <NavContainer id="_IDGenNavContainer">
      <Page id="pageSummary" showHeader="false" >
         <VBox id="_IDGenVBox2" class="sapUiSmallMargin">
            <f:Card id="_IDGenCard">
               <f:content>
                     <VBox id="_IDGenVBox11">
                        <Toolbar id="_IDGenToolbar2" height="3rem" class="sapUiSmallPaddingBeginEnd">
                           <Title id="_IDGenTitle" text="Rules Summary" class="sapUiSmallMarginBegin" />
                           <ToolbarSpacer id="_IDGenToolbarSpacer2" />

                              <SearchField id="_IDGenSearchField" width= "300px"
                                          placeholder="Search rules"
                                          liveChange="onSearch" />

                           <ToolbarSpacer id="_IDGenToolbarSpacer" />

                           <Button id="_IDGenButton1" text="Create new rule"
                                    type="Emphasized"
                                    press="onCreateNewRule"/>

                           <Button id="_IDGenButton2" text="Edit selected rule"
                                    type="Emphasized"
                                    press="onEditRule"/>  

                           <Button id="_IDGenButton3" text="Delete selected rule"
                                    type="Emphasized"
                                    press="onDeleteRule"
                                    class="sapUiSmallMarginEnd"
                           />                 
                        </Toolbar>

                        <Table id="_IDGenTable"
                                 mode="MultiSelect"
                                 width="100%"
                                 class="table"
                                 items="{app>/rules}"
                                 >
                           <columns>
                              <Column id="_IDGenColumn1" width="4rem" class="sapUiSmallMargin"><Text id="_IDGenText" text="ID" class="sapUiSmallMarginBegin"/></Column>
                              <Column id="_IDGenColumn2" minScreenWidth="Tablet"><Text id="_IDGenText2" text="Name"/></Column>
                              <Column id="_IDGenColumn3" minScreenWidth="Tablet"><Text id="_IDGenText3" text="Description"/></Column>
                              <Column id="_IDGenColumn4" width="7rem"><Text id="_IDGenText4" text="Valid from"/></Column>
                              <Column id="_IDGenColumn5" width="7rem"><Text id="_IDGenText5" text="Valid to"/></Column>
                              <Column id="_IDGenColumn6" width="6rem"><Text id="_IDGenText6" text="Item type"/></Column>
                              <Column id="_IDGenColumn7" minScreenWidth="Tablet"><Text id="_IDGenText7" text="Type of rule"/></Column>
                              <Column id="_IDGenColumn8" minScreenWidth="Tablet"><Text id="_IDGenText8" text="Plants" class="sapUiSmallMarginEnd"/></Column>
                           </columns>    

                           <items>
                                 <ColumnListItem id="_IDGenColumnListItem" >
                                    <cells>
                                       <Text id="_IDGenText10" text="{app>ID}"  class="sapUiSmallMarginBegin"  />
                                       <Text id="_IDGenText11" text="{app>Name}" />
                                       <Text id="_IDGenText12" text="{app>Description}" />
                                       <Text id="_IDGenText13" text="{app>ValidFrom}" />
                                       <Text id="_IDGenText14" text="{app>ValidTo}" />
                                       <Text id="_IDGenText15" text="{app>ItemType}" />
                                       <Text id="_IDGenText16" text="{app>RuleType}" />
                                       <Text id="_IDGenText17" text="{app>Plants}" class="sapUiSmallMarginEnd"/>
                                    </cells>
                                 </ColumnListItem>
                           </items>    
                        </Table>
                     </VBox>
               </f:content>
            </f:Card>
         </VBox>
      </Page>

      <Page id="pageGenInfo" showHeader="false" >
         <core:Fragment
         fragmentName="managerules.view.GenInfo"
         type="XML"
         />
      </Page>
    </NavContainer>
</mvc:View>