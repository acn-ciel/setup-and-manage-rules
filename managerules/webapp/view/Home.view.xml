<mvc:View
    controllerName="managerules.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:plugins="sap.m.plugins"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:rowmodes="sap.ui.table.rowmodes"
>
    <NavContainer id="_IDGenNavContainer">
        <f:DynamicPage
            id="dynamicPageId"
            toggleHeaderOnTitleClick="true"
            xmlns="sap.m"
            xmlns:f="sap.f"
            fitContent="false"
        >
            <f:title>
                <f:DynamicPageTitle id="_IDGenDynamicPageTitle" class="sapMTBNoBorder">
                    <f:heading>
                        <Title id="_IDGenTitle" text="Rules Summary" />
                    </f:heading>
                    <f:expandedContent>
                        <Label
                            id="expandedLabel"
                            text="No filters active"
                        /> 
                    </f:expandedContent>
                    <f:snappedContent>
                        <Label
                            id="snappedLabel"
                            text="No filters active"
                        />
                    </f:snappedContent>
                </f:DynamicPageTitle>
            </f:title>

            <f:header>
                <f:DynamicPageHeader id="_IDGenDynamicPageHeader">
                    <f:content>
                        <fb:FilterBar
                            id="filterbar"
                            persistencyKey="myPersKey"
                            useToolbar="false"
                            search=".onFilterSearch"
                        >
                            <fb:filterGroupItems>
                                <fb:FilterGroupItem
                                    id="_IDGenFilterGrpItem1"
                                    name="SearchAll"
                                    label="Search"
                                    groupName="Group1"
                                    visibleInFilterBar="true"
                                >
                                    <fb:control>
                                        <SearchField
                                            id="searchField1"
                                            width="200px"
                                            placeholder="e.g. 4010"
                                        />
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem
                                    id="_IDGenFilterGrpItem2"
                                    name="SearchRuleId"
                                    label="Search Rule Id"
                                    groupName="Group1"
                                    visibleInFilterBar="true"
                                >
                                    <fb:control>
                                        <SearchField
                                            id="searchField2"
                                            width="200px"
                                            placeholder="e.g. 20"
                                        />
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem
                                    id="_IDGenFilterGrpItem3"
                                    name="ItemType"
                                    label="Item Type"
                                    groupName="Group1"
                                    visibleInFilterBar="true"
                                >
                                    <fb:control>
                                        <MultiComboBox
                                            id="idGenItemTypeMCBFilter"
                                            name="ItemType"
                                            selectionChange=".onSelectionChange"
                                            items="{
												path: 'zsd_itemtype_vh>/ZI_ITEMTYPE_VH',
												templateShareable: true 
											}"
                                        >
                                            <core:Item
                                                id="_IDGenItem1"
                                                key="{zsd_itemtype_vh>ItemType}"
                                                text="{zsd_itemtype_vh>ItemTypeName}"
                                            />
                                        </MultiComboBox>
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem
                                    id="_IDGenFilterGrpItem4"
                                    name="TypeOfRule"
                                    label="Type of Rule"
                                    groupName="Group1"
                                    visibleInFilterBar="true"
                                >
                                    <fb:control>
                                        <ComboBox
                                            id="idGenRuleTypeMCBFilter"
                                            name="TypeOfRule"
                                            selectionChange=".onSelectionChange"
                                            items="{
												path: 'zsd_typerules_vh>/ZI_TYPERULES_VH',
												templateShareable: true
                                 }"
                                        >
                                            <core:Item
                                                id="_IDGenItem2"
                                                key="{zsd_typerules_vh>IndexNo}"
                                                text="{zsd_typerules_vh>TypeOfRules}"
                                            />
                                        </ComboBox>
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem
                                    id="_IDGenFilterGrpItem5"
                                    name="Plants"
                                    label="Plants"
                                    groupName="Group1"
                                    visibleInFilterBar="true"
                                >
                                    <fb:control>
                                        <MultiComboBox
                                            id="_IDGenMCB"
                                            name="Plants"
                                            selectionChange=".onSelectionChange"
                                            items="{
												path: 'zsd_plant_vh>/zi_plant_vh',
												templateShareable: true
                                 }"
                                        >
                                            <core:Item
                                                id="_IDGenItem3"
                                                key="{zsd_plant_vh>Plant}"
                                                text="{zsd_plant_vh>PlantName}"
                                            />
                                        </MultiComboBox>
                                    </fb:control>
                                </fb:FilterGroupItem>
                            </fb:filterGroupItems>
                        </fb:FilterBar>
                    </f:content>
                </f:DynamicPageHeader>
            </f:header>

            <f:content>
                <t:Table
                    id="_IDGenTable2"
                    rows="{zsd_ruleslist>/ZC_RULESLIST}"
                    selectionMode="MultiToggle"
                    width="100%"
                    class="table"
                >
                    <t:extension>
                        <Toolbar
                            id="_IDGenToolbar4"
                            height="3rem"
                            class="sapUiSmallPaddingBeginEnd sapUiSmallPaddingTop"
                        >
                            <ToolbarSpacer id="_IDGenToolSpacer" />
                            <Button
                                id="_IDGenButton1"
                                text="Create rule"
                                type="Emphasized"
                                press="onCreateNewRule"
                            />

                            <Button
                                id="_IDGenButton2"
                                text="Edit selected rule"
                                press="onEditRule"
                            />

                            <Button
                                id="_IDGenButton3"
                                text="Delete selected rule"
                                type="Reject"
                                press="onDeleteRule"
                            />
                        </Toolbar>
                    </t:extension>

                    <t:rowMode>
                        <rowmodes:Auto id="_IDGenAuto" />
                    </t:rowMode>

                    <t:columns>
                        <t:Column
                            sortProperty="RuleId"
                            id="_IDGenGridApplyCol23"
                            width="6rem"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl23"
                                text="{i18n>RULE_ID}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt52"
                                    text="{zsd_ruleslist>RuleId}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column
                            sortProperty="RuleName"
                            id="_IDGenGridApplyCol24"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl24"
                                text="{i18n>RULE_NAME}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt53"
                                    text="{zsd_ruleslist>RuleName}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column
                            sortProperty="RuleDescription"
                            id="_IDGenGridApplyCol25"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl25"
                                text="{i18n>RULE_DESCRIPTION}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt54"
                                    text="{zsd_ruleslist>RuleDescription}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column
                            sortProperty="ValidFrom"
                            id="_IDGenGridApplyCol26"
                            width="8rem"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl26"
                                text="{i18n>RULE_VALID_FROM}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt55"
                                    text="{zsd_ruleslist>ValidFrom}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column
                            sortProperty="ValidTo"
                            id="_IDGenGridApplyCol27"
                            width="8rem"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl27"
                                text="{i18n>RULE_VALID_TO}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt56"
                                    text="{zsd_ruleslist>ValidTo}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column
                            sortProperty="ItemType"
                            id="_IDGenGridApplyCol28"
                            width="6rem"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl28"
                                text="{i18n>RULE_ITEM_TYPE}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt57"
                                    text="{zsd_ruleslist>ItemType}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column
                            sortProperty="TypeOfRules"
                            id="_IDGenGridApplyCol29"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl29"
                                text="{i18n>RULE_RULETYPE}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt58"
                                    text="{zsd_ruleslist>TypeOfRules}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column
                            sortProperty="PlantName"
                            id="_IDGenGridApplyCol30"
                            resizable="true"
                        >
                            <Label
                                id="_IDGenGridApplyLbl30"
                                text="{i18n>RULE_PLANTS}"
                                wrapping="true"
                            />
                            <t:template>
                                <Text
                                    id="_IDGenGridApplyTxt59"
                                    text="{zsd_ruleslist>PlantName}"
                                    wrapping="true"
                                />
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>
            </f:content>
        </f:DynamicPage>

        <Page
            id="pageGenInfo"
            showHeader="false"
        >
            <core:Fragment
                fragmentName="managerules.view.GenInfo"
                type="XML"
            />
        </Page>
    </NavContainer>
</mvc:View>
