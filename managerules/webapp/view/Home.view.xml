<mvc:View controllerName="managerules.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:plugins="sap.m.plugins"
    >

   <NavContainer id="_IDGenNavContainer">
      <Page id="pageSummary" showHeader="false" >
         <Toolbar id="_IDGenToolbar2" height="5rem" class="sapUiSmallPaddingBeginEnd">
            <SearchField id="_IDGenSearchField" width= "300px"
                           placeholder="Search rules"
                           liveChange="onSearch" 
                           class="sapUiLargeMarginBegin sapUiSmallMarginTop" />

            <ToolbarSpacer id="_IDGenToolbarSpacer" />

            <Button id="_IDGenButton1" text="Create new rule"
                     type="Emphasized"
                     press="onCreateNewRule"
                     class="sapUiSmallMarginTop" />

            <Button id="_IDGenButton2" text="Edit selected rule"
                     type="Emphasized"
                     press="onEditRule"
                     class="sapUiSmallMarginTop" />  

            <Button id="_IDGenButton3" text="Delete selected rule"
                     type="Emphasized"
                     press="onDeleteRule"
                     class="sapUiLargeMarginEnd sapUiSmallMarginTop" />                 
         </Toolbar>
         <VBox id="_IDGenVBox2" class="sapUiSmallMargin">
            <f:Card id="_IDGenCard">
               <f:content>
                     <VBox id="_IDGenVBox11">
                        <Toolbar id="_IDGenToolbar4" height="3rem" class="sapUiSmallPaddingBeginEnd sapUiSmallPaddingTop">
                           <Title id="_IDGenTitle" text="Rules Summary" class="sapUiSmallMarginBegin" />
                        </Toolbar>

                        <t:Table
                           id="_IDGenTable"                 
                           rows="{
                              path: '/ZC_RULESHEADER',
                              parameters: {
                                 $select: 'RuleId,RuleName,RuleDescription,ValidFrom,ValidTo,ItemType,RuleType',
                                 $expand: '_RuleScope($select=Plant)'
                              }
                           }"
                           selectionMode="MultiToggle"
                           width="100%"
                           class="table"
                           >

                           <t:columns>
                              <t:Column id="_IDGenGridColumn1" width="6rem" resizable="true">
                              <Label id="_IDGenGridLabel1" text="ID" />
                              <t:template>
                                 <Text id="_IDGenGridText1" text="{RuleId}" />
                              </t:template>
                              </t:Column>

                              <t:Column id="_IDGenGridColumn2" resizable="true">
                              <Label id="_IDGenGridLabel2" text="Name" />
                              <t:template>
                                 <Text id="_IDGenGridText2" text="{RuleName}" />
                              </t:template>
                              </t:Column>

                              <t:Column id="_IDGenGridColumn3" resizable="true">
                              <Label id="_IDGenGridLabel3" text="Description" />
                              <t:template>
                                 <Text id="_IDGenGridText3" text="{RuleDescription}" wrapping="true" />
                              </t:template>
                              </t:Column>

                              <t:Column id="_IDGenGridColumn4" width="7rem" resizable="true">
                              <Label id="_IDGenGridLabel4" text="Valid from" />
                              <t:template>
                                 <Text id="_IDGenGridText4" text="{ValidFrom}" />
                              </t:template>
                              </t:Column>

                              <t:Column id="_IDGenGridColumn5" width="7rem" resizable="true">
                              <Label id="_IDGenGridLabel5" text="Valid to" />
                              <t:template>
                                 <Text id="_IDGenGridText5" text="{ValidTo}" />
                              </t:template>
                              </t:Column>

                              <t:Column id="_IDGenGridColumn6" width="6rem" resizable="true">
                              <Label id="_IDGenGridLabel6" text="Item type" />
                              <t:template>
                                 <Text id="_IDGenGridText6" text="{ItemType}" />
                              </t:template>
                              </t:Column>

                              <t:Column id="_IDGenGridColumn7" resizable="true">
                              <Label id="_IDGenGridLabel7" text="Type of rule" />
                              <t:template>
                                 <Text id="_IDGenGridText7" text="{RuleType}" />
                              </t:template>
                              </t:Column>

                              <t:Column id="_IDGenGridColumn8" resizable="true">
                              <Label id="_IDGenGridLabel8" text="Plants" />
                              <t:template>
                                 <Text
                                    id="_IDGenGridText8"
                                    text="{
                                    path: '_RuleScope',
                                    targetType: 'any',
                                    formatter: '.formatPlants'
                                    }"
                                    wrapping="true"
                                 />
                              </t:template>
                              </t:Column>

                           </t:columns>
                        </t:Table>
                     </VBox>
               </f:content>
            </f:Card>
         </VBox>
      </Page>

      <Page id="pageGenInfo" showHeader="false" >
         <core:Fragment
         fragmentName="managerules.view.GenInfo"
         type="XML"
         />
      </Page>
    </NavContainer>
</mvc:View>