<core:FragmentDefinition
xmlns:core="sap.ui.core"
xmlns="sap.m"
xmlns:l="sap.ui.layout.form"
>

<WizardStep id="StepFilters" title="Filters" >

<Toolbar id="_IDGenToolbar3" class="sapUiSmallMarginBottom" >
   <Text id="_IDGenText18" text="Filter item records in SFM where adjustment needs to be applied" />
   <ToolbarSpacer id="_IDGenToolbarSpacer4" />
   <Button id="_IDGenButton6" text="Add" type="Emphasized" press="onAddFilter" />
   <Button id="_IDGenButton7" text="Edit" type="Emphasized" press="onEditFilter" />
   <Button id="_IDGenButton8" text="Delete" type="Emphasized" press="onDeleteFilter" />
   <Button id="_IDGenButton9" text="Save and Next" type="Emphasized" press="onSaveAndNext" />  
</Toolbar>

<Table id="tblFilters"
       mode="MultiSelect"
       inset="false"
       width="100%" 
       items="{rules>/filter}">

   <columns>
     <Column id="_IDGenColumn9" ><Text id="_IDGenText19" text="Characteristic" /></Column>
     <Column id="_IDGenColumn10" ><Text id="_IDGenText20" text="Operator" /></Column>
     <Column id="_IDGenColumn11" ><Text id="_IDGenText21" text="Value" /></Column>
     <Column id="_IDGenColumn12" ><Text id="_IDGenText22" text="Value UoM" /></Column>
     <Column id="_IDGenColumn34" ><Text id="_IDGenText60" text="Logical Condition" /></Column>
   </columns>    

   <items>
    <ColumnListItem id="_IDGenColumnListItem2" >
     <cells>
      <Text id="_IDGenText23" text="{rules>Characteristic}" />
      <Text id="_IDGenText24" text="{rules>Operator}" />
      <Text id="_IDGenText25" text="{rules>Value}" />
      <Text id="_IDGenText26" text="{rules>ValueUom}" />
      <ComboBox id="_IDGenComboBox2" selectedKey="{rules>LogicalOperator}" width="10rem" placeholder="AND / OR" selectionChange=".onLogicalOperatorChange">
        <core:Item id="_IDGenItem52" key="1" text="AND"></core:Item>
        <core:Item id="_IDGenItem53" key="2" text="OR"></core:Item>
      </ComboBox>
     </cells>
    </ColumnListItem>
   </items>
    
</Table>

</WizardStep>

</core:FragmentDefinition>