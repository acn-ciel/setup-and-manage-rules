<core:FragmentDefinition
xmlns:core="sap.ui.core"
xmlns="sap.m"
xmlns:l="sap.ui.layout.form"
>

<WizardStep id="StepFilters" title="Filters">

  <Toolbar id="_IDGenToolbar3" class="sapUiSmallMarginBottom">
    <Text id="_IDGenText18" text="Filter item records in SFM where adjustment needs to be applied" />
    <ToolbarSpacer id="_IDGenToolbarSpacer4" />
    <Button id="_IDGenButton9" text="Add Group" type="Emphasized" press=".onAddGroup" />  
    <Button id="_IDGenButton21" text="{i18n>GENINFO_SAVE_NEXT_BTN}" type="Emphasized" press="onValidateNextStep" />  
  </Toolbar>

  <VBox id="_IDGenVBox" 
    items="{
      path: 'rules>/groupsFilter',
      templateShareable: false
    }">
      <Panel id="_IDGenPanel1" expandable="true" backgroundDesign="Solid" class="sapUiTinyMarginTop">
      
        <headerToolbar>
          <OverflowToolbar id="ToolBar">
            <Title id="Title" text="{rules>GroupName}" level="H4"/>
            <ToolbarSpacer id="_IDGenToolbarSpacer5" />
            <Button id="btnEdit1" text="Edit Group Name" press=".onEditGroupName"/>
            <Button id="btnDelete1" text="Delete Group" type="Reject" press=".onDeleteGroup"/>
          </OverflowToolbar>
        </headerToolbar>

        <Table id="_IDGenTable1" 
          items="{
            path: 'rules>_FilterCondition',
            templateShareable: false
          }" mode="MultiSelect">

          <columns>
            <Column id="Col1" ><Text id="Text1" text="Characteristic"/></Column>
            <Column id="Col2"><Text id="Text2" text="Operator"/></Column>
            <Column id="Col3"><Text id="Text3" text="Value"/></Column>
            <Column id="Col4"><Text id="Text4" text="Value UoM"/></Column>
            <Column id="colVal" hAlign="End">
              <header>
                <HBox id="hdrActionsRow" width="100%" justifyContent="End">
                  <Button id="btnAdd" icon="sap-icon://add" type="Transparent" press=".onAddFilter"/>
                  <Button id="btnEdit" icon="sap-icon://edit" type="Transparent" press=".onEditFilter" class="sapUiTinyMarginBegin"/>
                  <Button id="btnDelete" icon="sap-icon://delete" type="Transparent" press=".onDeleteFilter" class="sapUiTinyMarginBegin"/>
                </HBox>
              </header>
            </Column>
          </columns>

          <items>
            <ColumnListItem id="ColList1"> 
              <cells>
                <Text id="Text5" 
                  text="{
                  path: 'rules>Characteristic',
                  formatter: '.characteristicFormatter'
                  }" />
                <Text id="Text6" 
                  text="{
                  path: 'rules>Operator',
                  formatter: '.operatorFormatter'}"/>
                <Text id="Text7" 
                  text="{
                  path: 'rules>_FilterValues/0/Value',
                  formatter: '.productFormatter'
                  }" wrapping="true"/>
                <Text id="Text8" 
                  text="{
                  path: 'rules>_FilterValues/0/ValueUom',
                  formatter: '.valueUomFormatter'}" wrapping="true"/>
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </Panel>
  </VBox>
  
</WizardStep>

</core:FragmentDefinition>