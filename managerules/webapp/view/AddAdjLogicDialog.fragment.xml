<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:layout="sap.ui.layout.form">
    <Dialog id="dlgAddAdjLogic"
        title="Define adjustment logic"
        draggable="true"
        resizable="true"
        contentWidth="700px"
        contentHeight="auto"
        afterClose="onCancelAddAdjLogic">

        <HBox id="_IDGenHBox" class="sapUiSmallMargin" justifyContent="SpaceBetween">
            <VBox id="_IDGenVBox3" width="32%">
                <Label id="_IDGenLabel8" text="Logic" labelFor="selLogic" required="true"/>
                <ComboBox id="selLogic" width="100%" placeholder="Select logic to apply" items="{rules>/logic}">
                    <items>
                        <core:Item id="_IDGenItem18" key="{rules>IndexNo}" text="{rules>Logic}" />
                    </items>
                </ComboBox>
            </VBox>

            <VBox id="_IDGenVBox4" width="32%">
                <Label id="_IDGenLabel9" text="Value" labelFor="selLogicValue" required="true"/>
                <ComboBox id="selLogicValue" width="100%" placeholder="Select 1" items="{rules>/values}">
                    <items>
                        <core:Item id="_IDGenItem19" key="{rules>IndexNo}" text="{rules>LogicValues}" />
                    </items>
                </ComboBox>
            </VBox>

            <VBox id="_IDGenVBox6" width="32%">
                <Label id="_IDGenLabel10" text="Value UoM" labelFor="selLogicUoM"/>
                <ComboBox id="selLogicUoM" width="100%" placeholder="Select 1">
                    <core:Item id="_IDGenItem20" key="" text="Not Applicable" ></core:Item>
                </ComboBox>
            </VBox>
        </HBox>

        <beginButton>
            <Button id="_IDGenButton4" text="Add" press="onConfirmAddAdjLogic"/>
        </beginButton>
        <endButton>
            <Button id="_IDGenButton15" text="Cancel" press="onCancelAddAdjLogic"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>