<core:FragmentDefinition
xmlns:core="sap.ui.core"
xmlns="sap.m"
xmlns:l="sap.ui.layout.form"
>
<WizardStep id="StepAdjLogic" title="Adjustment Logic" >

  <Toolbar id="_IDGenToolbar5">
    <Text id="_IDGenText30" text="Define adjustment logic to filtered item records. " />
    <ToolbarSpacer id="_IDGenToolbarSpacer6"/>
    <Button id="_IDGenButton12" text="Save rule" type="Emphasized" press="onValidateNextStep" />
  </Toolbar>
  
  <Table id="tblAdjLogic2" 
          mode="MultiSelect"
          inset="false"
          width="100%"
          items="{rules>/draftadjlogic}">
      <columns>
        <Column id="_IDGenColumn" ><Text id="_IDGenText31" text="Logic" /></Column>
        <Column id="_IDGenColumn13" ><Text id="_IDGenText32" text="Value" /></Column>
        <Column id="_IDGenColumn14" ><Text id="_IDGenText33" text="Value UoM" /></Column>
        <Column id="colButtons" hAlign="End">
          <header>
            <HBox id="hdrActionsRow1" width="100%" justifyContent="End">
              <Button id="btnAdd1" icon="sap-icon://add" type="Transparent" press=".onAddAdjLogic"/>
              <Button id="btnEdit2" icon="sap-icon://edit" type="Transparent" press=".onEditAdjLogic" class="sapUiTinyMarginBegin"/>
              <Button id="btnDelete2" icon="sap-icon://delete" type="Transparent" press=".onDeleteAdjLogic" class="sapUiTinyMarginBegin"/>
            </HBox>
          </header>
        </Column>
      </columns>    
      <items>
        <ColumnListItem id="_IDGenColumnListItem1" >
          <cells>
            <Text id="_IDGenText40" 
            text="{
            path: 'rules>Logic',
            formatter: '.logicFormatter'
            }" />
            <Text id="_IDGenText41"  
            text="{
            path: 'rules>Value',
            formatter: '.valAdjLogFormatter'
            }" />
            <Text id="_IDGenText42"  
            text="{
            path: 'rules>ValueUom',
            formatter: '.valUomAdjLogicFormatter'}" />
          </cells>
        </ColumnListItem>
      </items>
  </Table>
 
</WizardStep>
</core:FragmentDefinition>