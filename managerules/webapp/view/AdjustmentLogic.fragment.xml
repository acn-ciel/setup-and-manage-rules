<core:FragmentDefinition
xmlns:core="sap.ui.core"
xmlns="sap.m"
xmlns:l="sap.ui.layout.form"
>
<WizardStep id="StepAdjLogic" title="Adjustment Logic" >

  <Toolbar id="_IDGenToolbar5">
    <Text id="_IDGenText30" text="Define adjustment logic to filtered item records. " />
    <ToolbarSpacer id="_IDGenToolbarSpacer6"/>
    <Button id="_IDGenButton16" text="Add" type="Emphasized" press="onAddAdjLogic" />
    <Button id="_IDGenButton10" text="Edit" type="Emphasized" press="onEditAdjLogic" />
    <Button id="_IDGenButton11" text="Delete" type="Emphasized" press="onDeleteAdjLogic" />
    <Button id="_IDGenButton12" text="Save rule" type="Emphasized" press="onSaveAndNext" />
  </Toolbar>
  
  <Table id="tblAdjLogic2" 
          mode="MultiSelect"
          inset="false"
          width="100%"
          items="{rules>/adjlogic}">
      <columns>
        <Column id="_IDGenColumn" ><Text id="_IDGenText31" text="Logic" /></Column>
        <Column id="_IDGenColumn13" ><Text id="_IDGenText32" text="Value" /></Column>
        <Column id="_IDGenColumn14" ><Text id="_IDGenText33" text="Value UoM" /></Column>
      </columns>    
      <items>
        <ColumnListItem id="_IDGenColumnListItem1" >
          <cells>
            <Text id="_IDGenText40" text="{rules>Logic}" />
            <Text id="_IDGenText41"  text="{rules>Value}" />
            <Text id="_IDGenText42"  text="{rules>ValueUom}" />
          </cells>
        </ColumnListItem>
      </items>
  </Table>
 
</WizardStep>
</core:FragmentDefinition>