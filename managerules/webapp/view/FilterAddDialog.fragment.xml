<core:FragmentDefinition
      xmlns="sap.m"
      xmlns:core="sap.ui.core">

  <Dialog id="dlgAddFilter"
          title="Define filter characteristics"
          draggable="true"
          resizable="true"
          contentWidth="60%"
          contentHeight="auto"
          afterClose="onFilterDialogClose"
          >

    <VBox id="_IDGenVBox5">
      <Table
          id="tblAdd"
          inset="false"
          width="100%"
          showSeparators="None">
        <columns>
          <Column id="_IDGenColumn15" width="120%"><Label id="_IDGenText29" text="Characteristic" required="true"/></Column>
          <Column id="_IDGenColumn16" width="90%"><Label id="_IDGenText34" text="Operator" required="true"/></Column>
          <Column id="_IDGenColumn17" width="100%"><Label id="_IDGenText35" text="Values" required="true"/></Column>
          <Column id="_IDGenColumn18" width="90%"><Label id="_IDGenText36" text="Value UoM" required="{rules>/selectChar}"/></Column>
        </columns>
        <items>
          <ColumnListItem id="_IDGenColumnListItem3">
            <cells>
              <ComboBox id="selCharacteristic"
                      class="select"
                      required="true"
                      placeholder="Select characteristic to apply"
                      items="{zsd_characteristic_vh>/ZI_CHARACTERISTIC_VH}"
                      selectionChange=".onCharacteristicsChange"
                      width="100%">
                <core:Item id="_IDGenItem25" key="{zsd_characteristic_vh>IndexNo}" text="{zsd_characteristic_vh>Characteristic}"/>
              </ComboBox>

              <ComboBox id="selOperator" 
                      class="select"
                      placeholder="Select operator"
                      items="{zsd_operator_vh>/ZI_OPERATOR_VH}"
                      width="100%">
                <core:Item id="_IDGenItem28" key="{zsd_operator_vh>Operator}" text="{zsd_operator_vh>OperatorDesc}"/>
              </ComboBox>

              <VBox id="InputValueContainer">
                <ComboBox id= "inpValue" 
                      class="select"
                      placeholder="Select 1"
                      items="{zsd_product_vh>/ZI_PRODUCT_VH}"
                      visible="false"
                      width="100%" >
                <core:Item id="_IDGenItem16" key="{zsd_product_vh>Product}" text="{zsd_product_vh>ProductName}" />    
                </ComboBox>
                
                <Input
                  id="_IDGenInput"
                  visible="false"
                  type="Number" 
                  width="100%"
                  />
                
                <DatePicker id="idFilterDP"
                  visible="false"
                  displayFormat="yyyy-MM-dd" 
                  valueFormat="yyyy-MM-dd" 
                  placeholder="{i18n>GENINFO_DATE_PH}" 
                  width="100%"/>
              </VBox>

              <ComboBox id="selUoM"
                      placeholder="Select 1"
                      items="{zsd_uom_vh>/ZI_UOM_VH}"
                      enabled="{rules>/selectChar}"
                      width="100%">
                <core:Item id="_IDGenItem31" key="{zsd_uom_vh>UnitOfMeasure}" text="{zsd_uom_vh>UnitOfMeasureLongName}"/>
              </ComboBox>
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </VBox>

    <endButton>
      <Button id="_IDGenButton13" text="Cancel" type="Transparent"
              press="onCancelAddFilter"/>
    </endButton>

    <beginButton>
      <Button id="_IDGenButton14" text="Add" type="Emphasized"
              press=".onConfirmAddFilter"/>
    </beginButton>

  </Dialog>
</core:FragmentDefinition>