<core:FragmentDefinition
      xmlns="sap.m"
      xmlns:core="sap.ui.core">

  <Dialog id="dlgAddFilter"
          title="Define filter characteristics"
          draggable="true"
          resizable="true"
          contentWidth="60%"
          contentHeight="auto"
          afterClose="onFilterDialogClose"
          >

    <VBox id="_IDGenVBox5">
      <Table
          id="tblAdd"
          inset="false"
          width="100%"
          showSeparators="None">
        <columns>
          <Column id="_IDGenColumn15" width="130%"><Label id="_IDGenText29" text="Characteristic" required="true"/></Column>
          <Column id="_IDGenColumn16" width="90%"><Label id="_IDGenText34" text="Operator" required="true"/></Column>
          <Column id="_IDGenColumn17" width="90%"><Label id="_IDGenText35" text="Values" required="true"/></Column>
          <Column id="_IDGenColumn18" width="90%"><Label id="_IDGenText36" text="Value UoM" required="{= ${rules>/selectChar} !== '1' }"/></Column>
        </columns>
        <items>
          <ColumnListItem id="_IDGenColumnListItem3">
            <cells>
              <ComboBox id="selCharacteristic"
                      class="select"
                      required="true"
                      placeholder="Select characteristic to apply"
                      selectedKey="{rules>/selectChar}"
                      items="{rules>/characteristics}"
                      selectionChange=".onCharacteristicsChange"
                      width="100%">
                <core:Item id="_IDGenItem25" key="{rules>IndexNo}" text="{rules>Characteristic}"/>
              </ComboBox>

              <ComboBox id="selOperator" 
                      class="select"
                      placeholder="Select operator"
                      items="{rules>/operator}"
                      width="100%">
                <core:Item id="_IDGenItem28" key="{rules>Operator}" text="{rules>OperatorDesc}"/>
              </ComboBox>

              <VBox id="InputValueContainer">
                <ComboBox id= "inpValue" 
                      class="select"
                      placeholder="Select 1"
                      items="{rules>/product}"
                      visible="false"
                      width="100%" >
                <core:Item id="_IDGenItem16" key="{rules>Product}" text="{rules>ProductName}" />    
                </ComboBox>
                
                <Input
                  id="_IDGenInput"
                  visible="false"
                  type="Number" />
              </VBox>

              <ComboBox id="selUoM"
                      placeholder="Select 1"
                      items="{rules>/valueUom}"
                      enabled="{= ${rules>/selectChar} !== '1' }"
                      width="100%">
                <core:Item id="_IDGenItem31" key="{rules>UnitOfMeasure}" text="{rules>UnitOfMeasureLongName}"/>
              </ComboBox>
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </VBox>

    <endButton>
      <Button id="_IDGenButton13" text="Cancel" type="Transparent"
              press="onCancelAddFilter"/>
    </endButton>

    <beginButton>
      <Button id="_IDGenButton14" text="Add" type="Emphasized"
              press="onConfirmAddFilter"/>
    </beginButton>

  </Dialog>
</core:FragmentDefinition>