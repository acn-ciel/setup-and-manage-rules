<mvc:View
    controllerName="applyrules.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:plugins="sap.m.plugins"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:rowmodes="sap.ui.table.rowmodes"
>
    <f:DynamicPage
        id="dynamicPageId"
        toggleHeaderOnTitleClick="true"
        xmlns:m="sap.m"
        xmlns:f="sap.f"
    >
        <f:title>
            <f:DynamicPageTitle
                id="_IDGenDynamicPageTitle"
                class="sapMTBNoBorder"
            >
                <f:heading>
                    <VBox id="_IDGenVBox">
                        <Title
                            id="_IDGenTitle"
                            text="Apply Rules"
                        />
                    </VBox>
                </f:heading>
                <f:expandedContent>
                    <Label
                        id="expandedLabel"
                        text="No filters active"
                    />
                </f:expandedContent>
                <f:snappedContent>
                    <Label
                        id="snappedLabel"
                        text="No filters active"
                    />
                </f:snappedContent>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader id="_IDGenDynamicPageHeader">
                <f:content>
                    <fb:FilterBar
                        id="filterbar"
                        persistencyKey="myPersKey"
                        useToolbar="false"
                        search=".onFilterSearch"
                        filterChange=".onFilterChange"
                        afterVariantLoad=".onAfterVariantLoad"
                    >
                        <fb:filterGroupItems>
                            <fb:FilterGroupItem
                                id="_IDGenFilterGrp1"
                                name="SearchAll"
                                label="Search"
                                groupName="Group1"
                                visibleInFilterBar="true"
                            >
                                <fb:control>
                                    <SearchField
                                        id="_IDGenSearchField1"
                                        width="300px"
                                        placeholder="e.g. 4010"
                                    />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem
                                id="_IDGenFilterGrp2"
                                name="SearchRuleId"
                                label="Rule Id"
                                groupName="Group1"
                                visibleInFilterBar="true"
                            >
                                <fb:control>
                                    <SearchField
                                        id="searchField2"
                                        width="200px"
                                        placeholder="e.g. 20"
                                    />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem
                                id="_IDGenFilterGrp3"
                                name="ItemType"
                                label="Item Type"
                                groupName="Group1"
                                visibleInFilterBar="true"
                            >
                                <fb:control>
                                    <MultiComboBox
                                        id="idGenItemTypeMCBFilter"
                                        name="ItemType"
                                        selectionChange=".onSelectionChange"
                                        items="{
                                            path: 'zsd_itemtype_vh>/ZI_ITEMTYPE_VH',
                                            templateShareable: true 
                                        }"
                                    >
                                        <core:Item
                                            id="_IDGenItem"
                                            key="{zsd_itemtype_vh>ItemType}"
                                            text="{zsd_itemtype_vh>ItemTypeName}"
                                        />
                                    </MultiComboBox>
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem
                                id="_IDGenFilterGrp4"
                                name="TypeOfRule"
                                label="Type of Rule"
                                groupName="Group1"
                                visibleInFilterBar="true"
                            >
                                <fb:control>
                                    <ComboBox
                                        id="idGenRuleTypeCBFilter"
                                        name="TypeOfRule"
                                        selectionChange=".onSelectionChange"
                                        items="{
                                            path: 'zsd_typerules_vh>/ZI_TYPERULES_VH',
                                            templateShareable: true
                                }"
                                    >
                                        <core:Item
                                            id="_IDGenItem1"
                                            key="{zsd_typerules_vh>IndexNo}"
                                            text="{zsd_typerules_vh>TypeOfRules}"
                                        />
                                    </ComboBox>
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem
                                id="_IDGenFilterGrp5"
                                name="Plants"
                                label="Plants"
                                groupName="Group1"
                                visibleInFilterBar="true"
                            >
                                <fb:control>
                                    <MultiComboBox
                                        id="idGenRuleTypeMCBPlant"
                                        name="Plants"
                                        selectionChange=".onSelectionChange"
                                        items="{
                                            path: 'zsd_plant_vh>/zi_plant_vh',
                                            templateShareable: true
                                }"
                                    >
                                        <core:Item
                                            id="_IDGenItem3"
                                            key="{zsd_plant_vh>Plant}"
                                            text="{zsd_plant_vh>PlantName}"
                                        />
                                    </MultiComboBox>
                                </fb:control>
                            </fb:FilterGroupItem>
                        </fb:filterGroupItems>
                    </fb:FilterBar>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <t:Table
                id="_IDGenTable2"
                rows="{app>/applyRules}"
                selectionMode="MultiToggle"
                width="100%"
                class="table">
                <t:extension>
                    <Toolbar
                        id="_IDGenToolbar5"
                        height="3rem"
                        class="sapUiSmallPaddingBeginEnd sapUiSmallPaddingTop">
                        <ToolbarSpacer id="_IDGenToolBarSpacer" />
                        <Button id="_IDGenButton21" text="{i18n>BUTTON_ADD}"
                            type="Emphasized"
                            press="onAddApplyRule"/>
                        <Button id="_IDGenButton22" text="{i18n>BUTTON_DELETE}"
                            type="Reject"
                            press="onDeleteSelectedApplyRules"/>
                        <Button id="_IDGenButton23" text="{i18n>BUTTON_EXEC}"
                            type="Emphasized"
                            press="onExecuteApplyRule"/>  
                    </Toolbar>
                </t:extension>

                <t:rowMode>
                    <rowmodes:Auto id="_IDGenAuto" />
                </t:rowMode>

                <t:columns>
                    <t:Column
                        sortProperty="RuleId"
                        id="_IDGenGridApplyCol"
                        width="6rem"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl"
                            text="{i18n>RULE_ID}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt"
                                text="{app>RuleId}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>

                    <t:Column
                        sortProperty="RuleName"
                        id="_IDGenGridApplyCol2"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl2"
                            text="{i18n>RULE_NAME}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt2"
                                text="{app>RuleName}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>

                    <t:Column
                        sortProperty="RuleDescription"
                        id="_IDGenGridApplyCol1"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl3"
                            text="{i18n>RULE_DESCRIPTION}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt3"
                                text="{app>RuleDescription}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>

                    <t:Column
                        sortProperty="ValidFrom"
                        id="_IDGenGridApplyCol3"
                        width="8rem"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl4"
                            text="{i18n>RULE_VALID_FROM}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt4"
                                text="{app>ValidFrom}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>

                    <t:Column
                        sortProperty="ValidTo"
                        id="_IDGenGridApplyCol4"
                        width="8rem"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl5"
                            text="{i18n>RULE_VALID_TO}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt5"
                                text="{app>ValidTo}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>

                    <t:Column
                        sortProperty="ItemTypeFormatted"
                        id="_IDGenGridApplyCol5"
                        width="6rem"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl6"
                            text="{i18n>RULE_ITEM_TYPE}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt6"
                                text="{app>ItemType}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>

                    <t:Column
                        sortProperty="RuleTypeFormatted"
                        id="_IDGenGridApplyCol7"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl7"
                            text="{i18n>RULE_RULETYPE}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt7"
                                text="{app>TypeOfRules}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>

                    <t:Column
                        sortProperty="PlantFormatted"
                        id="_IDGenGridApplyCol8"
                        resizable="true"
                    >
                        <Label
                            id="_IDGenGridApplyLbl8"
                            text="{i18n>RULE_PLANTS}"
                            wrapping="true"
                        />
                        <t:template>
                            <Text
                                id="_IDGenGridApplyTxt8"
                                text="{app>PlantName}"
                                wrapping="true"
                            />
                        </t:template>
                    </t:Column>
                </t:columns>
            </t:Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>
